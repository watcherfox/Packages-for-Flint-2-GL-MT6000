name: Build SmartDNS (OpenWrt 25.12 Flint2)

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-22.04

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install deps
        run: |
          sudo apt update
          sudo apt install -y build-essential clang flex bison g++ gawk \
          gcc-multilib g++-multilib gettext git libncurses-dev libssl-dev \
          python3-distutils rsync unzip zlib1g-dev file wget

      - name: Download OpenWrt 25.12 SDK (Filogic)
        run: |
          wget https://downloads.openwrt.org/releases/25.12.0/targets/mediatek/filogic/openwrt-sdk-25.12.0-mediatek-filogic_gcc-13.2.0_musl.Linux-x86_64.tar.xz
          tar -xf openwrt-sdk-*.tar.xz
          mv openwrt-sdk-* sdk

      - name: Clone SmartDNS (PikuZheng)
        run: |
          git clone -b PikuZheng https://github.com/Ljzkirito/smartdns-openwrt.git package/smartdns

      - name: Prepare feeds
        working-directory: sdk
        run: |
          ./scripts/feeds update -a
          ./scripts/feeds install -a

      - name: Add package
        run: |
          mv package/smartdns sdk/package/

      - name: Configure
        working-directory: sdk
        run: |
          make defconfig

      - name: Build package
        working-directory: sdk
        run: |
          make package/smartdns/compile V=s -j$(nproc)

      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: smartdns-apk
          path: sdk/bin/packages/*/*/smartdns*.apk
